# Mahala CHIRPS pipeline configuration.
# Copy this file to ".env" and adjust if needed. Every setting has a working
# default, so an empty/unedited .env still runs.

# Where all generated data is stored.
# Leave blank to use the "data" folder next to the scripts (works on any OS).
# Set to an absolute or relative path to store data elsewhere.
DATA_ROOT=

# Boundary input file (relative to the repo root, or an absolute path).
BOUNDARY_GEOJSON=Mahala.geojson

# Farmer GPS coordinates for the CHIRPS snap/score helpers (tools/snap_score.py and
# tools/pilot_launch_check.py); relative to repo root or absolute. The single place to
# swap farm coordinates for those tools: any CSV with lat/lon and an id column named
# farmer_id, mahsooli_id or id. Extra columns (e.g. radius_m) are ignored. After
# swapping, re-run only `python tools/snap_score.py` (steps 0-3 unaffected).
# (The NDVI pipeline uses its own NDVI_FARMERS_CSV below - a stricter schema.)
SNAP_FARMERS_CSV=data/farmers/farmers.csv

# Period to process (inclusive).
START_YEAR=2014
END_YEAR=2024

# In-season months as a comma-separated list (6=June ... 9=September).
SEASON_MONTHS=6,7,8,9

# Keep the downloaded .tif.gz archive after unzipping (true/false).
# Set to false to delete the .gz after unzip and halve raw storage.
KEEP_GZ=true

# CHIRPS v2.0 africa_monthly source (rarely needs changing).
BASE_URL=https://data.chc.ucsb.edu/products/CHIRPS-2.0/africa_monthly/tifs

# Filename product prefix: <PREFIX>.<year>.<MM>.tif(.gz), e.g. chirps-v2.0.2014.06.tif.
PRODUCT_PREFIX=chirps-v2.0

# Download retry count and per-request timeout in seconds.
DOWNLOAD_RETRIES=3
DOWNLOAD_TIMEOUT=120

# NoData value written into clipped/derived rasters.
NODATA=-9999.0

# CHIRPS grid cell size in degrees (used for GPS -> grid-key snapping).
CELL_SIZE=0.05

# ============================================================================
# NDVI crop-health monitoring (Google Earth Engine + Sentinel-2)
# Separate sub-pipeline: ndvi_run_pipeline.py (ndvi_0 -> ndvi_1 -> ndvi_2).
# Every key has a working default; only the EE/Sheet credentials must be filled in.
# ============================================================================

# Baseline-donor plot registry (tracked in git, phones stripped). Columns:
# plot_id, farmer_name, sector (rainfed|irrigated), locality, village,
# geometry_type (polygon|point), geometry_wkt, lat, lon, area_feddan, radius_m,
# seasons (';'-separated cotton planting years), notes.
NDVI_PLOTS_REGISTRY=data/farmers/baseline_plots.csv

# Financed-farmer plots CSV (columns: mahsooli_id, lat, lon, optional radius_m,
# optional sector). Only monitored when NDVI_MONITOR_FARMERS=true.
NDVI_FARMERS_CSV=data/farmers/farmers.csv
NDVI_MONITOR_FARMERS=true

# --- Google Earth Engine ---
# REQUIRED: the registered Cloud project EE runs against (ee.Initialize(project=...)).
# The service account needs roles/serviceusage.serviceUsageConsumer AND the Earth
# Engine "Writer" role, and the project must be registered at
# https://code.earthengine.google.com/register?project=<EE_PROJECT_ID>
EE_PROJECT_ID=

# CI / headless: the WHOLE service-account key JSON as a single-line string.
# Wire to a GitHub Secret. May be the SAME service account used for the Sheet.
GEE_SERVICE_ACCOUNT_INFO=

# Local: path to a service-account JSON key file (e.g. .tokens/mahala-sa-key.json).
GEE_SERVICE_ACCOUNT_JSON=

# --- Sentinel-2 / NDVI (rarely need changing) ---
S2_COLLECTION=COPERNICUS/S2_SR_HARMONIZED
NDVI_NIR_BAND=B8
NDVI_RED_BAND=B4
NDVI_SCALE_M=10
FARMER_RADIUS_M=100

# Cloud masking method: "scl" (default, per the PRD) or "cloudscore" (Cloud Score+,
# better over arid bright soil). SCL_DROP_CLASSES are dropped when method=scl.
CLOUD_MASK_METHOD=scl
SCL_DROP_CLASSES=3,8,9,10,11
CLOUD_SCORE_PLUS_COLLECTION=GOOGLE/CLOUD_SCORE_PLUS/V1/S2_HARMONIZED
CLOUD_SCORE_PLUS_BAND=cs_cdf
CLOUD_SCORE_PLUS_MIN=0.60

# --- Baseline (sector methodology) ---
# One cotton season Y = Jun 1 (Y) -> Mar 31 (Y+1), binned into 44 season-weeks.
# Each donor plot contributes only its listed cotton seasons; seasons before
# MIN_SEASON_YEAR are skipped (no Sentinel-2 SR over Sudan before ~Dec 2018).
SEASON_START_MONTH=6
SEASON_START_DAY=1
SEASON_END_MONTH=3
SEASON_END_DAY=31
MIN_SEASON_YEAR=2019
NDVI_WEEK_DAYS=7
BASELINE_MIN_COUNT=3

# --- Current pull + alert thresholds ---
NDVI_CURRENT_WINDOW_DAYS=10
# Min cloud-free observations before a current reading is trusted (else "No data").
# 1 = old behaviour (only fully-cloudy windows); higher = stricter.
NDVI_CURRENT_MIN_COUNT=2
NDVI_DEVIATION_ALERT_PCT=-20
NDVI_VEG_FLOOR=0.2
NDVI_ABS_DROP_FLOOR=0.05

# --- Output Google Sheet (raw Sheets API v4) ---
# Existing, human-created spreadsheet; share it (Editor) with the service-account email.
# Service accounts cannot create/own Sheets, so this must already exist.
NDVI_SHEET_ID=
NDVI_SHEET_TAB=NDVI_Log
# Off by default so a plain run never writes to the Sheet; enable here or pass --push.
NDVI_SHEET_PUSH=false

# --- Imagery exports (raw clipped S2 + NDVI GeoTIFF, RGB + NDVI PNG per plot) ---
# Saved each cycle into data/ndvi/runs/<date>_cycle/imagery and via the on-demand
# CLI (python ndvi/exports.py --plot BP008 --season 2024).
NDVI_EXPORT_ENABLED=true
NDVI_REQUIRE_EXPORTS=true
NDVI_EXPORT_BANDS=B2,B3,B4,B8
# Also export imagery for the baseline DONOR plots (one set per usable season)
# into data/ndvi/runs/<date>_baseline/imagery, so the raw S2/NDVI rasters behind
# each sector baseline are archived alongside the CSVs. Set false to skip on a
# quota-constrained baseline build.
NDVI_BASELINE_EXPORT_IMAGERY=true

# --- Google Cloud Storage run archive (traceability) ---
# Mirror each dated run folder (imagery + tables + run_log.json) to
# gs://GCS_BUCKET/GCS_ARCHIVE_PREFIX/<date>_<kind>/. The bucket lives in the same
# Cloud project as Earth Engine, so by default this reuses the EE service account
# (GEE_SERVICE_ACCOUNT_INFO/_JSON) - just grant it roles/storage.objectAdmin on
# the bucket. Re-uploads skip objects of unchanged size unless GCS_OVERWRITE=true.
# Master switch: archive EVERY epic's deliverables to GCS, classified by date:
#   gs://GCS_BUCKET/<YYYY-MM-DD>/e1.1-chirps/   (lookup CSVs + average/seasonal rasters + boundary)
#   gs://GCS_BUCKET/<YYYY-MM-DD>/e1.2-baseline/ (baseline CSVs + imagery incl. baseline NDVI)
#   gs://GCS_BUCKET/<YYYY-MM-DD>/e1.2-cycle/    (cycle log + imagery)
#   gs://GCS_BUCKET/<YYYY-MM-DD>/e1.3-pilot/    (pilot sign-off xlsx/csv/txt)
GCS_ARCHIVE=false
# Back-compat: enables E1.2 archiving on its own even if GCS_ARCHIVE is false.
NDVI_GCS_ARCHIVE=false
GCS_BUCKET=
# Optional folder inside the bucket (empty = bucket root); use only if the bucket
# is shared with unrelated data.
GCS_DATA_PREFIX=
GCS_OVERWRITE=false
# Also mirrors just the NDVI GeoTIFFs into a dedicated, browsable folder so clients
# can find them without opening run folders:
# gs://GCS_BUCKET/NDVI_TIFF_PREFIX/<baseline|current>/<date>/<plot>_..._ndvi.tif.
NDVI_TIFF_PREFIX=ndvi
# Optional: use a separate key for GCS instead of the EE credentials.
GCS_SERVICE_ACCOUNT_INFO=
GCS_SERVICE_ACCOUNT_JSON=
